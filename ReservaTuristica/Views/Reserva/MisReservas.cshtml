@model List<ReservaTuristica.Domain.Entities.Reserva>

<h1>Mis Reservas</h1>

@if (!Model.Any())
{
    <div class="alert alert-info">

        No tienes reservas.

    </div>
}
else
{
    <table class="table table-bordered">

        <thead>

            <tr>

                <th>Alojamiento</th>
                <th>Fecha Inicio</th>
                <th>Fecha Fin</th>
                <th>Personas</th>
                <th>Habitaciones</th>
                <th>Acción</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>
                        @item.Alojamiento.Nombre
                    </td>

                    <td>
                        @item.FechaInicio.ToShortDateString()
                    </td>

                    <td>
                        @item.FechaFin.ToShortDateString()
                    </td>

                    <td>
                        @item.NumeroPersonas
                    </td>

                    <td>
                        @item.NumeroHabitaciones
                    </td>

                    <td>

                        <a asp-action="Eliminar"
                           asp-route-id="@item.Id"
                           class="btn btn-danger">

                            Eliminar

                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>
}